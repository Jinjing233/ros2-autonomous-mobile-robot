<?xml version="1.0"?>
<!--
  Shared mechanical parameters and materials for the AMR platform.
  Included by amr.urdf.xacro and amr.gazebo.xacro (simulation overlay).
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Chassis -->
  <xacro:property name="chassis_length" value="0.500"/>
  <xacro:property name="chassis_width" value="0.400"/>
  <xacro:property name="chassis_height" value="0.120"/>
  <xacro:property name="chassis_mass" value="20.0"/>

  <!-- Drive wheels -->
  <xacro:property name="wheel_radius" value="0.050"/>
  <xacro:property name="wheel_width" value="0.040"/>
  <xacro:property name="wheel_mass" value="0.800"/>
  <xacro:property name="wheel_separation" value="0.320"/>
  <xacro:property name="wheel_x_offset" value="0.000"/>
  <xacro:property name="wheel_z_offset" value="-0.060"/>

  <!-- Passive caster -->
  <xacro:property name="caster_radius" value="0.025"/>
  <xacro:property name="caster_width" value="0.020"/>
  <xacro:property name="caster_mass" value="0.200"/>
  <xacro:property name="caster_x_offset" value="0.180"/>
  <xacro:property name="caster_y_offset" value="0.000"/>
  <!-- Align caster ground contact with drive wheels (smaller radius → lower joint z) -->
  <xacro:property name="caster_z_offset" value="${wheel_z_offset - wheel_radius + caster_radius}"/>

  <!-- Sensors (mount poses relative to base_link) -->
  <xacro:property name="laser_x_offset" value="0.000"/>
  <xacro:property name="laser_y_offset" value="0.000"/>
  <xacro:property name="laser_z_offset" value="0.140"/>
  <xacro:property name="laser_radius" value="0.035"/>
  <xacro:property name="laser_height" value="0.040"/>
  <xacro:property name="laser_mass" value="0.300"/>

  <xacro:property name="imu_x_offset" value="0.000"/>
  <xacro:property name="imu_y_offset" value="0.000"/>
  <xacro:property name="imu_z_offset" value="0.060"/>
  <xacro:property name="imu_size" value="0.030"/>
  <xacro:property name="imu_mass" value="0.010"/>

  <!-- Derived: base_link height so wheel contact meets ground at base_footprint -->
  <xacro:property name="base_link_z" value="${wheel_radius - wheel_z_offset}"/>

  <material name="chassis_grey">
    <color rgba="0.60 0.60 0.62 1.0"/>
  </material>
  <material name="wheel_black">
    <color rgba="0.12 0.12 0.12 1.0"/>
  </material>
  <material name="caster_grey">
    <color rgba="0.30 0.30 0.32 1.0"/>
  </material>
  <material name="laser_dark">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>
  <material name="imu_blue">
    <color rgba="0.20 0.40 0.80 1.0"/>
  </material>

</robot>
