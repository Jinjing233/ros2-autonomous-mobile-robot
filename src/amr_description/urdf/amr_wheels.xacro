<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="wheel_roll" value="1.57079632679"/>

  <xacro:macro name="drive_wheel" params="prefix y_offset">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${wheel_roll} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${wheel_roll} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="${wheel_roll} 0 0"/>
        <mass value="${wheel_mass}"/>
        <inertia
          ixx="${wheel_mass / 12.0 * (3.0 * wheel_radius * wheel_radius + wheel_width * wheel_width)}"
          ixy="0.0"
          ixz="0.0"
          iyy="${wheel_mass / 2.0 * wheel_radius * wheel_radius}"
          iyz="0.0"
          izz="${wheel_mass / 12.0 * (3.0 * wheel_radius * wheel_radius + wheel_width * wheel_width)}"/>
      </inertial>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin
        xyz="${wheel_x_offset} ${y_offset} ${wheel_z_offset}"
        rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:macro name="amr_wheels">
    <xacro:drive_wheel prefix="left" y_offset="${wheel_separation / 2.0}"/>
    <xacro:drive_wheel prefix="right" y_offset="${-wheel_separation / 2.0}"/>
  </xacro:macro>

</robot>
